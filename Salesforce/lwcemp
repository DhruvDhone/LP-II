44. Replace employeeManagement.js with this code:

import { LightningElement } from 'lwc';
import { createRecord } from 'lightning/uiRecordApi';
import { ShowToastEvent } from 'lightning/platformShowToastEvent';

import EMPLOYEE_OBJECT from '@salesforce/schema/Employee__c';
import NAME_FIELD from '@salesforce/schema/Employee__c.Name';
import EMPLOYEE_ID_FIELD from '@salesforce/schema/Employee__c.Employee_ID__c';
import SALARY_FIELD from '@salesforce/schema/Employee__c.Salary__c';
import EMAIL_FIELD from '@salesforce/schema/Employee__c.Email__c';
import DEPARTMENT_FIELD from '@salesforce/schema/Employee__c.Department__c';
import JOINING_DATE_FIELD from '@salesforce/schema/Employee__c.Joining_Date__c';

export default class EmployeeManagement extends LightningElement {
    employeeName = '';
    employeeId = '';
    salary = '';
    email = '';
    department = '';
    joiningDate = '';

    errorMessage = '';
    successMessage = '';

    departmentOptions = [
        { label: 'HR', value: 'HR' },
        { label: 'IT', value: 'IT' },
        { label: 'Finance', value: 'Finance' },
        { label: 'Sales', value: 'Sales' },
        { label: 'Marketing', value: 'Marketing' }
    ];

    handleNameChange(event) {
        this.employeeName = event.target.value;
    }

    handleIdChange(event) {
        this.employeeId = event.target.value;
    }

    handleSalaryChange(event) {
        this.salary = event.target.value;
    }

    handleEmailChange(event) {
        this.email = event.target.value;
    }

    handleDepartmentChange(event) {
        this.department = event.detail.value;
    }

    handleDateChange(event) {
        this.joiningDate = event.target.value;
    }

    validateForm() {
        this.errorMessage = '';
        this.successMessage = '';

        if (!this.employeeName || this.employeeName.trim().length < 3) {
            this.errorMessage = 'Employee Name cannot be empty and must contain at least 3 characters.';
            return false;
        }

        if (!this.employeeId || Number(this.employeeId) <= 0) {
            this.errorMessage = 'Employee ID must be greater than 0.';
            return false;
        }

        if (!this.salary || Number(this.salary) <= 10000 || Number(this.salary) >= 500000) {
            this.errorMessage = 'Salary must be greater than 10,000 and less than 500,000.';
            return false;
        }

        const emailPattern = /^[^\\s@]+@[^\\s@]+\\.[^\\s@]+$/;

        if (!this.email || !emailPattern.test(this.email)) {
            this.errorMessage = 'Email address must follow a valid email format.';
            return false;
        }

        if (!this.department) {
            this.errorMessage = 'Department must be selected from the available list.';
            return false;
        }

        if (!this.joiningDate) {
            this.errorMessage = 'Joining Date is required.';
            return false;
        }

        const today = new Date();
        today.setHours(0, 0, 0, 0);

        const selectedDate = new Date(this.joiningDate);

        if (selectedDate > today) {
            this.errorMessage = 'Joining Date cannot be a future date.';
            return false;
        }

        return true;
    }

    saveEmployee() {
        if (!this.validateForm()) {
            this.showToast('Error', this.errorMessage, 'error');
            return;
        }

        const fields = {};

        fields[NAME_FIELD.fieldApiName] = this.employeeName;
        fields[EMPLOYEE_ID_FIELD.fieldApiName] = this.employeeId;
        fields[SALARY_FIELD.fieldApiName] = this.salary;
        fields[EMAIL_FIELD.fieldApiName] = this.email;
        fields[DEPARTMENT_FIELD.fieldApiName] = this.department;
        fields[JOINING_DATE_FIELD.fieldApiName] = this.joiningDate;

        const recordInput = {
            apiName: EMPLOYEE_OBJECT.objectApiName,
            fields: fields
        };

        createRecord(recordInput)
            .then(() => {
                this.successMessage = 'Employee record created successfully.';
                this.errorMessage = '';
                this.showToast('Success', 'Employee record created successfully.', 'success');
                this.clearForm();
            })
            .catch(error => {
                this.successMessage = '';

                if (error.body && error.body.message) {
                    this.errorMessage = error.body.message;
                } else {
                    this.errorMessage = 'Error while creating employee record.';
                }

                this.showToast('Error', this.errorMessage, 'error');
            });
    }

    clearForm() {
        this.employeeName = '';
        this.employeeId = '';
        this.salary = '';
        this.email = '';
        this.department = '';
        this.joiningDate = '';
        this.errorMessage = '';
        this.successMessage = '';
    }

    showToast(title, message, variant) {
        const event = new ShowToastEvent({
            title: title,
            message: message,
            variant: variant
        });

        this.dispatchEvent(event);
    }
}

